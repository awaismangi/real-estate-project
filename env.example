# MongoDB Atlas connection string
# Example: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/nexhome?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/nexhome?retryWrites=true&w=majority

# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# Default seeded admin account (username/email + password)
# These are used by `npm run seed` to create the default admin user.
ADMIN_NAME=Admin
ADMIN_EMAIL=admin
ADMIN_PASSWORD=admin

# Comma-separated list of allowed origins for CORS (your frontend dev/prod URLs)
CLIENT_ORIGIN=http://localhost:5173
